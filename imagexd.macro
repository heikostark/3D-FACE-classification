//!./imagexd // Version: 8.12.26
// This is a list of imagexd commands - you can use this macro like a programing language
// For more infos, please see https://stark-jena.de | imagexd
// Copyright (c) 2017-2026 by Heiko Stark

io.file.remove "imagexd.macro" // remove old command list
execute ./imagexd // make new command list
halt // Do not interpret the rest
// *************************************************

// @variable denotes builtin variables.
// Assignment := are only used if the stack type is the same (image := image.func) or a result (10 := image.func).

// *************************************************

clean // same as new
new // clean memory - all scalar, vector, tensor, mesh and line
dump // dump // dump all scalar, vector, tensor, mesh and line workspace lists

// Absolute values are recommended. However, some commands also allow relative values (marked as %)!
// absolute: -max..-1:inverse 0:center 1..max:normal
// relative: -0.99999..-0.00001:inverse 0:center 0.00001..0.99999:normal

// *************************************************

imagemagick.enable // imagemagick.disable
freeimage.enable // freeimage.disable

a := image.ifimage // true, if the image has a size bigger than 0x0
a := image.ifplain // true, if the image has only one value for all

a := image.size // image size <x,y>
a := image.center // image center <x,y>
a := image.origin // image center <x,y>
a := image.matrix // image center <x,y>
a := image.matrix.v1 // image center <x,y>
a := image.matrix.v2 // image center <x,y>
a := image.matrix.v3 // image center <x,y>

// Note: The bit level is relevant, if a new image is created (i.e. image.load or first time image.use)!
image.8bit // set image workspace to 8bit
image.16bit // set image workspace to 16bit (Default)
image.24bit // set image workspace to 3*8bit rgb
image.32bit // set image workspace to 4*8bit rgba
image.40bit // set image workspace to 16bit+3*8bit zrgb

image.value 12 // set image value // 0..255; 0..65535; <0..255, 0..255, 0..255> or <0..255, 0..255, 0..255> 255
image.background 0 // set image background // 0..255; 0..65535; <0..255, 0..255, 0..255> or <0..255, 0..255, 0..255> 255

image.use new1 // create new image workspace
image.swap new1 new2 // swap images
image.name old1 // rename
image.dump // dump image workspace list

image.clean // clean image - same as image.new <0, 0>
image.new x y // or <x, y> or empty - clear field (1..x 1..y)
image.offset // set offset to zero
image.offset.center // set offset to the image center
image.offset <x, y, z> image.offset // set offset to zero
image.scale <x, y, z> // fill matrix with positive scaling
image.matrix <x1, y1, z1> <x2, y2, z2> <x3, y3, z3> // scale and rotation matrix
image.unflip // set matrix to positive values
image.unrotate // set matrix to diagonal matrix
a := image.l2g <x, y, z> // local to global coordinates
a := image.g2l <x, y, z> // global to local coordinates

image.load image.input // load a file
//      8bit+16bit (pnm, pbm, pgm, ppm, bmp, dib, imgf)
//      24bit+32bit (pnm, pbm, pgm, ppm, bmp, dib, rgb)
//      with Imagemagick (over 200 data formats, including PNG, JPEG, JPEG-2000, GIF, TIFF, DPX, EXR, WebP, Postscript, PDF, and SVG)
image.loadpnm image.input // load a pnm(pbm, pgm, ppm)-file
image.loadbmp image.input // load a bmp(dib)-file
image.loadimgf image.input // load a imgf-file (only 8bit+16bit)
image.loadrgb image.input // load a rgb-file (only 24bit+32bit)
image.loadraw image.input 0 100 100 // load a headerless (0) 100x100 rgb-file (only 16bit, 24bit or 32bit auto-detection)
image.save newfile // save a file
//      8bit+16bit (pgm, tif, png)
//      24bit+32bit (pbm, pgm, ppm, pam, bmp, dib, tga, tif, png, rgb)
//      with Imagemagick (over 200 data formats, including PNG, JPEG, JPEG-2000, GIF, TIFF, DPX, EXR, WebP, Postscript, PDF, and SVG)

image.crop 10 // crop an image to a new subimage with values below 10
new := image.copy // copy an image to new
image.copy.method 1 // 0=sum 1=mean(default) 2=sd 3=min 4=Q.25 5=median 6=Q.75 7=max // binning only for image.copyscale
new := image.copy // copy image field to new
new := image.copy 0.5 // isometric copy and scale image field to new
new := image.copy <0.5, 1> // anisometric copy and scale image field to new
new := image.resize <100, 100> // anisometric copy and resize the image field to new
new := image.copy.label 0.5 // copy and scale image field to new, without label averaging (max. value count)
new := image.subimage <10, 10> <20, 20> // %(abs & rel) copy part of the image to new
new := image.subimage.rel <10, 10> <10, 10> // %(abs & rel) same as above (pos size), copy part of the image to new

image.split.rgb // split rgb image into (name.red, name.green, name.blue) gray images
image.split.rgba // split rgba image into (name.red, name.green, name.blue, name.alpha) gray images
image.split.rainbow // split rgb image into (name.red, name.green, name.blue, name.yellow, name.cyan, name.purple, name.gray) gray images
image.split.rainbow.shift 2 // split (rgb8 -> rgb6) image into (see above) gray images (not shifted)
image.split.color <0, 0, 0> <255, 255, 255> ... // split image into several images with points nearest to color (name.1, name.2, ...)
image.split.colorpoint <10, 10> <100, 100> ... // %(abs & rel) split image into several images with points nearest to color at point (name.1, name.2, ...)
// Note: Fullgray images are divided by 256 (shr 8) and rgb converted to gray to fit in 8bit!
new := image.combine name.red name.green name.blue // combine gray images (only two, three or four) into rb, rgb (24bit) or rgba (32bit) image

new := image.select old1 6 // new := if old1 into value or range then set new to old1
new := image.select old1 6 1 // new := if old1 into value or range then set new to 1
new := image.select old1 <128, 255> // new := if old1 into value or range then set new to old1
new := image.select old1 <128, 255> 1 // new := if old1 into value or range then set new to 1
new := image.group old1 <128, 255> // new := if old1 into value or range then assign to group
new := image.group.add old1 <128, 255> // new := if old1 into value or range then assign to group
new := image.group.min old1 <128, 255> 99 // new := if old1 into value or range then assign to group (if group > 100 pixel)
new := image.group.minmax old1 <128, 255> <100, 200> // new := if old1 into value or range then assign to group (if group into 100..200 pixel)
// Can only be used with a previous grouping!
image.group.unsort // random sorting
image.group.sort.inverse false // default false
image.group.sort.count // max groups based on counts (borders, fractions)
image.group.sort.count 10 // 10 groups based on counts
image.group.sort.border 10 // 10 groups based on borders
image.group.sort.fraction 10 // 10 groups based on borders/volumes
image.group.sort.fraction.log 20 10 // 20 groups with log10
image.group.stat out.txt // write groupid border count border/count

// Note!: Only properties of "old" are copied if "new" has the size <0,0,0> (from image.new)
new := image.stacking old1 old2 ... // new := best parts of (old1 old2 ...)
new := image.over old1 old2 ... // new := old1 over old2 over ... // alpha blending
new := image.sub old1 old2 // new := old1 - old2
new := image.sub.abs old1 old2 // new := abs (old1 - old2)
new := image.sub.range old1 old2 // new := rangecenter + (old1 - old2)
new := image.between old1 between old2 // new := (between - old1) + (between - old2)
new := image.add old1 old2 // new := old1 + old2 // up to 99 images
new := image.add.min old1 old2 // new := min(old1,old2) // up to 99 images
new := image.add.max old1 old2 // new := max(old1,old2) // up to 99 images
new := image.mul old1 old2 // new := (old1 * old2) / (255 or 65535) // also new := (old1 * old2 * old3) / (255*255 or 65535*65535)
new := image.div old1 old2 // new := ((256 or 65536)*old1) / (old2+1)
new := image.mean old1 old2 // new := (old1 + old2)/2 // also new := (old1 + old2 + old3)/3
new := image.median old1 old2 old3 // new := old2 if old1 < old2 < old3
new := image.intensity old1 old2 1/2 1 // new := (old1/1/2 + old2/1)/2 * (1/2+1)/2 // intensity mapping for 1/2 s and 1 s

// Note!: Only properties of "old" are copied if "new" has the size <0,0,0> (from image.new)
new := image.mask old1 mask 0 <1, 10> ... // new := if mask = (0 or 1..10 or ...) use old1
new := image.mask.same old1 mask same 0.1 // new := if mask = same+/-10% use old1
new := image.mask.different old1 mask same 0.1 // new := if mask <> same+/-10% use old1
new := image.extract.color old1 <0, 0, 0> <255, 255, 255> ... // new := if (old1 = color) use old1
new := image.extract.colorpoint old1 <10, 10> <100, 100> ... // %(abs & rel) new := if (old1 = (color at point)) use old1

image.setsign // for wrapped values 32768..65535..0..32767 (signed values) -> 0..65535
image.setrange // put first value to zero (if wrapped values, it does setsign)
image.setcrop // for single spots (begin and end)
image.setlower 7 0 // set ...7 to 0
image.setvalue <7, 247> 247 // set for 8bit and 16bit -> 7..247 to 247
image.setvalue <128, 0, 0> <128, 0, 255> // set for 24bit and 32bit -> <128, 0, 0> to <128, 0, 255>
image.sethigher 247 247 // set 247... to 247
image.setadjust // adjust the gray or rgb level - e.g. 10..200 -> 0..255 or 0..65535
image.setadjust <10, 200> // adjust the gray or rgb level - eg. 10..200 -> 0..255 or 0..65535
image.setadjust <10, 200> <5, 250> // adjust the gray or rgb level - eg. 10..200 -> 5..250
image.setadjust.one // adjust the gray or rgb level - eg. (1%)±10..200±(1%) -> 0..255 or 0..65535
image.setadjust.percentage 0.05 // adjust the gray or rgb level - eg. (5%)±10..200±(5%) -> 0..255 or 0..65535
image.setadjust.percentage 0.05 0.01 // adjust the gray or rgb level - eg. (5%)±10..200±(1%) -> 0..255 or 0..65535
image.setadjust.percentage.weak 0.05 0.01 // adjust the gray or rgb level - eg. (5%)±10..200±(5%) -> 0..255 or 0..65535
image.setadjust.percentage.weak 0.05 0.01 0.03 0.01 // adjust the gray or rgb level - eg. (5%)±10..200±(3%) -> (1%)±0..255±(1%) or (1%)±0..65535±(1%)
image.setadjust.outliers // adjust the gray or rgb level - eg. (1/4(q2-q1))±10..200±(1/4(q3-q2)) -> 0..255 or 0..65535
image.setequal // adjust the gray or rgb level to an equal distribution

image.setpeaklower // eg. 100..peak..200 -> -50..0..50
image.setpeakmiddle // eg. 100..peak..200 -> 78..128..178 or 32718..32768..32818
image.setpeakhigher // eg. 100..peak..200 -> 205..255..305 or 65485..65535..65585

image.setpeak.local 128 <64, 192> // for a peak into 64..192 - eg. 100..peak..200 -> 78..128..178
image.setpeak.localred 128 <64, 192> // for a peak into red 64..192 - eg. all rgb 100..peak..200 -> 78..128..178
image.setpeak.localgreen 128 <64, 192> // for a peak into green 64..192 - eg. all rgb 100..peak..200 -> 78..128..178
image.setpeak.localblue 128 <64, 192> // for a peak into blue 64..192 - eg. all rgb 100..peak..200 -> 78..128..178

image.setbalance <-100, -100, -100> <-100, 0, 100> <100, 100, 100> // set for 24bit and 32bit -> color balance for shadows, midtones and highlights (with preserving luminosity)
image.setbalance.shadows <-100, -100, -100> // set for 24bit and 32bit -> color balance for shadows (with preserving luminosity)
image.setbalance.midtones <-100, 0, 100> // set for 24bit and 32bit -> color balance for midtones (with preserving luminosity)
image.setbalance.highlights <100, 100, 100> // set for 24bit and 32bit -> color balance for highlights (with preserving luminosity)

image.setmin.red <0, 0, 0> // set for 24bit and 32bit -> (<0, 255, 255>; <0,255,10>; <0,128,1>; ...) to <0, 0, 0>
image.setmin.green .blue, .yellow, .cyan, .purple - see above
image.setmax.red <0, 0, 0> // set for 24bit and 32bit -> (<255, 0, 0>; <255,250,10>; <255,128,254>; ...) to <0, 0, 0>
image.setmax.green .blue, .yellow, .cyan, .purple - see above

// color.map.volume1 5 100 // please define a colormap (100 means interpolation steps)
image.colorize // gray: 0..255, fullgray: 0..65535, rgb: rgba: 0..255+255+255

image.setmono 128 // binary value with threshold
image.setgray // only rgb and rgba
image.sethdrgray // only rgb and rgba

image.softsmooth 1 // default image.softsmooth
image.smooth 4 // 4 times smooth
image.hardsmooth 1
image.unsharpmasking 1
image.cleanup image.setadjust + image.smooth + 2*image.unsharpmasking

image.filter 0 1 0 1 0 1 0 1 0  4 // matrix [1..9] div [10]

image.fill // fill image with image.value
image.fill.random // fill image with random values
image.fill.cube <1, 1> <0,0> // fill subimage (1,1 .. x/2,y/2) with image.value
image.fill.hole <5, 15> // fill holes with image.value from structures 5..15
image.fill.zero // fill zeros with interpolated image values
image.fill.gap // fill zero holes with interpolated image values
image.fill.gap <10,10> <100,100> // fill zero holes inside area with interpolated image values
image.invert // invert image
image.invert 765 // invert image inside range 0..765 - only for 16bit

// Note: image.shrink = image.erode, image.fullshrink = image.fullerode, image.grow = image.dilate, image.fullgrow = image.fulldilate
image.shrink <128, 255> 4 // remove single spots, if 4 neighbors (max 8) outside value or range
image.shrink <128, 255> 4 1 // replace single spots with 1, if 4 neighbors (max 8) outside value or range
image.fullshrink (see above) // loop image.shrink until be found no more shrinking points or iteration steps > 9999
image.grow <128, 255> 4 // fill single hole, if 4 neighbors (max 8) inside value or range
image.grow <128, 255> 4 1 // replace single hole with 1, if 4 neighbors (max 8) inside value or range
image.fullgrow (see above) // loop image.grow until be found no more growing points or iteration steps > 9999
image.open (see above) // shrink + grow
image.close (see above) // grow + shrink
image.close <128, 255> 4 4 1 1 // grow <128, 255> 4 1 + shrink <128, 255> 4 1

image.remove.outliers 2 // if value outside of median+/-(factor * abs(q.25-q.75))

image.histogram // write histogram to stdout
image.histogram.image histogram.pgm // save histogram image
image.histogram.raw histogram.txt // save histogram values
image.analysis // write analysis to stdout
image.analysis.image analysis.pgm // save histogram + analysis image
image.analysis.raw analysis.txt // save histogram + analysis values

image.window.sin // Sine window function 
image.window.cos // Cosine window function

image.radial <0,0> // paint the angle values around center point
image.radial.half
image.radial.quater
image.distance <10,3> <100,23> .. // calculates the distance of each pixel to this points

image.flip.x
image.flip.y
image.rotate.90 // -270°
image.rotate.180 // -180°, (flip.x + flip.y)
image.rotate.270 // -90°
image.rotate.360 // -360°, 0°

image.getsphere <1,255> 10 // spheres with values <1,255> with max radius 10 stored in line as (x,y,z,r)

a := image.object.center 64 128 // as min q.25 q.50 q.75 max
a := image.object.center 64 1.5 128 // with 1.5 scaling 
a := image.object.size 64 128 // as value

a := image.getbackground // most pixel value
a := image.min // min pixel value
a := image.max // max pixel value
a := image.count 0 128 // pixel count with values from 0..128
a := image.sum 0 128 // pixel sum with values from 0..128
a := image.statistic 0 128 // pixel mean SD with values from 0..128
a := image.statistic 0 0.5 128 // pixel mean*0.5 SD*0.5 with values from 0..128
// mean a[1], sd a[2]
a := image.quantile 0 128 // pixel min q.25 median q.75 max with values from 0..128
a := image.quantile 0 0.5 128 // pixel min*0.5 q.25*0.5 median*0.5 q.75*0.5 max*0.5 with values from 0..128
// min a[1], q.25 a[2], median a[3], q.75 a[4], max a[5]
a := image.centroid 0 128 // centroid from values 0..128
a := image.cog 0 128 // cog from values 0..128

// Note: The diffusion method works best with isotropic pixels!
image.submethod 2 // 0=sum 1=mean 2=sd(default) 3=min 4=Q.25 5=median 6=Q.75 7=max
image.fullscan false // true = scan only full circles (without zero), false(default) = scan incomplete circles
image.diffusion.method 5 // 1=stark2013 2=stark2014a 3=stark2014b 4=stark2015a 5=stark2015b(default) 6=stark2019 // algorithm for image.diffusion
//       stark2013 = only the single best vector – vectorlength = submethod.SD
//       stark2014a = mean the two best vectors, if distance < r/2 – vectorlength = submethod.SD
//       stark2014b = mean (same submethod.SD) best vectors – vectorlength = submethod.SD
//       stark2015a = mean (same submethod.SD) best vectors (around diffusion.angle (rad)), only for diffusion.max (%)
//       stark2015b = mean the best vectors (around diffusion.angle (rad)), only for diffusion.max (%)
//       stark2019  = mean the best vectors (around diffusion.angle (rad)), only for diffusion.max (%) – vectorlength = submethod.SD
image.diffusion.max 0.25 // (%)
image.diffusion.angle 0.08726 // (rad) - 5*(pi/180) = 5°
new := image.diffusion 16 // calculate a image (orientation) field from a image with pixel scan length

image.vertical.sum // pixel sum output to stdout
image.vertical.sum 128 // from column 128 pixel output to stdout
image.vertical.sum 128 50 // from column 78-128-178 pixel sum output to stdout
image.vertical.mean (see above) // pixel mean output to stdout
image.vertical.sd (see above) // pixel SD output to stdout

image.horizontal.sum (see above) // pixel sum output to stdout
image.horizontal.mean (see above) // pixel mean output to stdout
image.horizontal.sd (see above) // pixel SD output to stdout

// *************************************************

a := scalar.ifscalar // true, if scalar has a size bigger than 0x0x0
a := scalar.ifplain // true, if scalar has only one value for all

a := scalar.size // scalar size <x,y,z>
a := scalar.center // scalar center <x,y,z>
a := scalar.origin // scalar center <x,y,z>
a := scalar.matrix // scalar center <x,y,z>
a := scalar.matrix.v1 // scalar center <x,y,z>
a := scalar.matrix.v2 // scalar center <x,y,z>
a := scalar.matrix.v3 // scalar center <x,y,z>

// Note: The bit level is relevant, if a new scalar is created (i.e. scalar.new, scalar.load or first time scalar.use)!
scalar.1bit // set scalar workspace to 1bit
scalar.8bit // set scalar workspace to 8bit
scalar.16bit // set scalar workspace to 16bit (Default)

scalar.value // set scalar value
scalar.background // set scalar background

// Note: ALL following functions using the scalar field from scalar.use!
scalar.use new1 // create a new scalar workspace
scalar.swap new1 new2 // swap scalars
scalar.name old1 // rename
scalar.dump // dump scalar workspace list

scalar.clean // clean scalar - same as scalar.new <0, 0, 0>
scalar.new x y z // or <x, y, z> or empty - new field (1..x 1..y 1..z)
scalar.offset // set offset to zero
scalar.offset.center // set offset to the field center
scalar.offset <x, y, z>
scalar.scale <x, y, z> // fill matrix with positive scaling
scalar.matrix <x1, y1, z1> <x2, y2, z2> <x3, y3, z3> // scale and rotation matrix
scalar.unflip // set matrix to positive values
scalar.unrotate // set matrix to diagonal matrix

a := scalar.l2g <x, y, z> // local to global coordinates
a := scalar.g2l <x, y, z> // global to local coordinates

scalar.labels.new // clear all labels
scalar.labels.clean // clear all labels

scalar.load.labels scalar.txt // load a label file (atlas.xml, tab separated [1#name] or plain [name]) - maximal 0-999 labels
count := scalar.labels.length // get number of labels
name := scalar.label 1 // get label name for index 1
scalar.label 1 "exterior" // set label name "exterior" for index 1
scalar.labels.dump // dump all labels
scalar.save.labels scalar.txt // save a label file

scalar.load.filter // reset load filter // see also setendian, setsign, setrange
scalar.load.filter 12000 // scoped filter (integer) 12000+value (Default 0)
scalar.load.filter 12000 10 // scoped filter (integer) values (12000+value)*10 (Default 0 1)
scalar.load.filter 12000 -2 // scoped filter (integer) values (12000+value)/2 (Default 0 1)
scalar.load scalar.input // load a file or files (nii, nii.gz, (hdr+img), mif, pcr and (pnm or bmp) stacks)
scalar.load.properties scalar.input // overwrite offset and matrix properties for active scalar field
scalar.load.hdr scalar.input // load a analyze7.5(hdr,img)-file
scalar.load.nii scalar.input // load a nifti-file (and .atlas.xml if available)
scalar.load.nii.gz scalar.input // load a zipped nifti-file
scalar.load.amira scalar.input // load a amira/avizo-file
scalar.load.mif scalar.input // load a mif-file
scalar.load.pcr scalar.input // load a (pcr,vol)-file
scalar.load.raw scalar.input 452 "byte" <10 , 10, 10> // load a raw-file (header=452 type=byte,word,longword,quadword,single,double,extended,rgb,rgba,wordrgb,wordrgba type=signbyte,...)
scalar.load.scale scalar.input <x, y, z>// load (pnm or bmp) stacks with specific scale)
scalar.append scalar.input // load a file or files (nii, nii.gz, (hdr+img), mdf and (pnm or bmp) stacks into a scalar field)
scalar.appendcenter scalar.input // load a centered file or files (nii, nii.gz, (hdr+img), mdf and (pnm or bmp) stacks into a scalar field)
scalar.save newfile // save a file (nii, nii.gz, (hdr+img) or (pnm, bmp, tga, tif or png))

scalar.flip.x
scalar.flip.y
scalar.flip.z

old := scalar.make.scalar // init scalar field with dimensions from the used scalar field
scalar.make.vector // init used vector field with dimensions from the used scalar field
old := scalar.make.vector // init vector field with dimensions from the used scalar field
scalar.crop <1, 10> // crop scalar field with value or range <1, 10>
new := scalar.crop <1, 10> // crop scalar field to new substack with value or range <1, 10>
new := scalar.crop old1 <1, 10> // crop scalar field old1 to new substack with value or range <1, 10>
new := scalar.crop old1 mask <1, 10> // crop scalar field old1 to new substack with mask value or range <1, 10>
scalar.move <10, 10, 10> <20, 20, 20> <0, 50, 50> // move block (<10, 10, 10> <20, 20, 20>) with <0, 50, 50> to <10, 60, 60>
scalar.copy.method 1 // for downscaling 0=sum 1=mean(default) 2=sd 3=min 4=Q.25 5=median 6=Q.75 7=max
                     // for upscaling 0=block 1=mean(default) 2=sinc
new := scalar.copy // copy scalar field to new
new := scalar.copy 0.5 // isometric copy and scale scalar field to new
new := scalar.copy <0.5, 0.5, 1> // anisometric copy and scale scalar field to new
new := scalar.resize <100, 100, 100> // anisometric copy and resize scalar field to new
new := scalar.copy.label 0.5 // copy and scale scalar field to new, without label averaging (max. value count)
new := scalar.substack <10, 10, 10> <20, 20, 20> // %(abs & rel) copy a part from scalar field to new

new := scalar.select old1 6 // new := if old1 into value or range then set new to old1
new := scalar.select old1 6 1 // new := if old1 into value or range then set new to 1
new := scalar.select old1 <128, 255> // new := if old1 into value or range then set new to old1
new := scalar.select old1 <128, 255> 1 // new := if old1 into value or range then set new to 1
new := scalar.group old1 <128, 255> // new := if old1 into value or range then assign to group
new := scalar.group.add old1 <128, 255> // new := if old1 into value or range then assign to group
new := scalar.group.min old1 <128, 255> 99 // new := if old1 into value or range then assign to group (if group > 99 pixels)
new := scalar.group.minmax old1 <128, 255> <100, 200> // new := if old1 into value or range then assign to group (if group into 100..200 pixel)
// Can only be used with a previous grouping!
scalar.group.unsort // random sorting
scalar.group.sort.inverse false // default false
scalar.group.sort.count // max groups based on count (border, fraction)
scalar.group.sort.count 10 // 10 groups based on count
scalar.group.sort.border 10 // 10 groups based on border
scalar.group.sort.fraction 10 // 10 groups based on border/count
scalar.group.sort.fraction.log 20 10 // 20 groups with log10
scalar.group.stat out.txt // write groupid border count border/count

// Note!: Only properties of "old" are copied if "new" has the size <0,0,0> (from scalar.new)
new := scalar.over old1 old2 // if old2 = 0 then new := old1 else new := old2 // up to 99 scalars
new := scalar.sub old1 old2 // new := old1 - old2
new := scalar.sub.abs old1 old2 // new := abs (old1 - old2)
new := scalar.sub.range old1 old2 // new := rangecenter + (old1 - old2)
new := scalar.between old1 between old2 // new := (between - old1) + (between - old2)
new := scalar.add old1 old2 // new := old1 + old2 // up to 99 scalars
new := scalar.add.min old1 old2 // new := min(old1,old2) // up to 99 scalars
new := scalar.add.max old1 old2 // new := max(old1,old2) // up to 99 scalars
new := scalar.mean old1 old2 // new := (old1 + old2)/2 // up to 99 scalars
new := scalar.mean.outliers old1 old2 // new := (old1 + old2)/2 // up to 99 scalars
new := scalar.median old1 old2 old3 // new := old2 if old1 < old2 < old3 // up to 99 scalars
new := scalar.median.outliers old1 old2 old3 // new := old2 if old1 < old2 < old3 // up to 99 scalars
new := scalar.intensity old1 old2 80 120 // new := (old1/80 + old2/120)/2 * (80+120)/2 // intensity mapping for 80 kV and 120 kV
new := scalar.intensity old1 old2 old3 80 100 120 // new := (old1/80 + old2/100 + old3/120)/3 * (80+100+120)/3 // intensity mapping for 80 kV, 100 kV and 120 kV

scalar.samples <64,128> old // store values from 64..128 into line
scalar.samples <64,128> old1 old2 // store old1 and old2 values if old1 (64..128) into line

// Note!: Only properties of "old" are copied if "new" has the size <0,0,0> (from scalar.new)
scalar.milling mask.xy mask.yz mask.xz // combination of scalar.milling...
new := scalar.milling.xy old1 mask 0 <1,10> ... // new := if mask = (0 or 1..10 or ...) use old1 // mask = image
new := scalar.milling.xz old1 mask 0 <1,10> ... // new := if mask = (0 or 1..10 or ...) use old1 // mask = image
new := scalar.milling.yz old1 mask 0 <1,10> ... // new := if mask = (0 or 1..10 or ...) use old1 // mask = image
new := scalar.mask old1 mask 0 <1, 10> ... // new := if mask = (0 or 1..10 or ...) use old1

scalar.magic mask.xy mask.yz mask.xz
