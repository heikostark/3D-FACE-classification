scalar.fullscan false // true = scan only full spheres (without zero), false(default) = scan incomplete spheres
new := scalar.measure.mean 10 // measure mean from all inside the block size 2*10 x 2*10 x 2*10
// You can ensure the correct storage of the floating point value via scalar.scale!
