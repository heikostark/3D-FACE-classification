mesh.gettensor.westin.rank 2.5 // westin ranked [rgb] (with max. depth 2.5) in tensor on vertex points stored in color vector

// *************************************************

line.use new1 // create a new line workspace
line.swap new1 new2 // swap lines
line.name old1 // rename
line.dump // dump line workspace list

line.clean // same as line.new
line.new

line.load line.input // load a cloud2 file
line.load line.input 20 // load only 20 % randomly from a cloud2 file
line.save newfile // save lines (obj, dxf, trk, mel, mv3d, swc or txt)
line.save.obj newfile // save lines (obj file) for Blender, 3D Slicer, ...
line.save.dxf newfile // save lines (dxf file) for CAD-software
line.save.vtk newfile // save lines (vtp, vtk file) for 3D Slicer
line.save.trackvis newfile // save lines (trk file) for TrackVis
line.save.maya newfile // save lines (mel file) for Maya
line.save.mv3d newfile // save lines (txt file) for MicroVisu3D
line.save.swc newfile // save lines (swc file)
line.save.txt newfile // save lines (txt file)

new := line.copy // copy line to new
new := line.copy 0.5 // isometric copy and scale line to new
new := line.copy <0.5, 0.5, 1> // anisometric copy and scale line to new – preserve t
new := line.copy <0.5, 0.5, 1, 2> // anisometric copy and scale line to new

line.center // center all
line.center.objects // center objects

line.number // store point number in t
line.distance // store near distance in t
line.length // store line length from the origin in t

line.mean.t // calculate the mean of all t values on lines
line.sd.t // calculate the SD of all t values on lines
line.min.t // calculate min of all t values on lines
line.median.t // calculate the median of all t values on lines
line.max.t // calculate max of all t values on lines

line.erase.duplicates // erase duplicates lines, vectors or points
line.erase.duplicates.near 1 // erase near lines, vectors or points
line.erase.duplicates.origin 1 // erase near origin lines, vectors or points
line.mean.duplicates.near 1 // mean near points

line.erase.t.min 10 // erase all lines with t < 10
line.erase.t.max 90 // erase all lines with t > 90

line.erase.length.min 10 // erase all lines with length < 10
line.erase.length.max 90 // erase all lines with length > 90

line.discrete 1 // <1.2,2.3,4.7,4.5> -> <1,2,5,5> // 1*(value/1)
line.discrete.3d 1 // <1.2,2.3,4.7,4.5> -> <1,2,5,4.5>

line.vector.norm // norm vectors
line.vector.normscale 2 // norm and scale vectors
line.vector.scale 2 // scale vectors
line.vector.minscale // scale vectors to 1/(min vector)
line.vector.maxscale // scale vectors to 1/(max vector)
line.vector.negate // negate (-1*) vectors
line.vector.invert // invert (1/) vectors

line.draw.value // set draw to scalar.value
line.draw.value.t // set draw to scalar.value*t
line.draw.t // set draw to t

line.draw.point // draw points into scalar
line.draw.point.solid // draw solid points into scalar
line.draw.sphere 3 // draw sphere with radius 3 into scalar
line.draw.sphere.solid 3 // draw solid sphere with radius 3 into scalar
line.draw.cube 3 // draw cube with radius 3 into scalar
line.draw.cube.solid 3 // draw solid cube with radius 3 into scalar
line.draw.line // draw lines into scalar
line.draw.line.solid // draw solid lines into scalar
line.draw // draw points or lines into scalar
line.draw.solid // draw solid points or lines into scalar

// For more line commands, look at Cloud2!

