scalar.fill.cave.y <128, 255> // fill from outside along y axis
scalar.fill.cave.z <128, 255> // fill from outside along z axis
scalar.convex.x <128, 255> // calculate convex hull (yz) and fill along x axis
scalar.convex.y <128, 255> // calculate convex hull (xz) and fill along y axis
scalar.convex.z <128, 255> // calculate convex hull (xy) and fill along z axis
scalar.fill.convex <128, 255> // fill from outside

scalar.remove.outliers 2 // if value outside of median+/-(factor * abs(q.25-q.75))

