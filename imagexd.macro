scalar.magic mask.xy mask2.xy mask.yz mask2.yz mask.xz
scalar.magic mask.xy mask2.xy mask.yz mask2.yz mask.xz mask2.xz
scalar.magic.color // same as magic but for colors

scalar.setendian // swap endianness $ABCD -> $CDAB
scalar.setsign // for wrapped values 32768..65535..0..32767 (signed values) -> 0..65535
scalar.setrange // shift first value to zero
scalar.setcrop // for single spots (begin and end)
scalar.setlower 7 0 // set ...7 to 0
scalar.setvalue <7, 247> 247 // set for 8bit and 16bit -> 7..247 to 247
scalar.sethigher 247 247 // set 247... to 247
scalar.setalpha <0, 255> 255 // set alpha 0..255 to 255
scalar.setadjust // adjust the gray level - eg. 10..200 -> 0..255 or 0..65535
scalar.setadjust <10, 200> // adjust the gray level - eg. 10..200 -> 0..255 or 0..65535
scalar.setadjust <10, 200> <5, 250> // adjust the gray level - eg. 10..200 -> 5..250
scalar.setadjust.one // adjust the gray level - eg. (1%)±10..200±(1%) -> 0..255 or 0..65535
scalar.setadjust.percentage 0.05 // adjust the gray level - eg. (5%)±10..200±(5%) -> 0..255 or 0..65535
scalar.setadjust.percentage 0.05 0.01 // adjust the gray level - eg. (5%)±10..200±(1%) -> 0..255 or 0..65535
scalar.setadjust.percentage.weak 0.05 0.01 // adjust the gray level - eg. (5%)±10..200±(5%) -> 0..255 or 0..65535
scalar.setadjust.percentage.weak 0.05 0.01 0.03 0.01 // adjust the gray level - eg. (5%)±10..200±(3%) -> (1%)±0..255±(1%) or (1%)±0..65535±(1%)
scalar.setadjust.outliers // adjust the gray level - eg. (1/4(q2-q1))±10..200±(1/4(q3-q2)) -> 0..255 or 0..65535
scalar.setequal // adjust the gray level to an equal distribution

scalar.setpeaklower // 100..peak..200 -> -50..0..50
scalar.setpeakhigher // 100..peak..200 -> 205..255..305 or 65485..65535..65585
scalar.setpeakmiddle // 100..peak..200 -> 78..128..178 or 32718..32768..32818

