scalar.diffusion.map map.pgm 16 // calculate diffusion map from one voxel with scan length at center point
scalar.diffusion.map map.pgm 16 <0, 0, 0> // calculate diffusion map from one voxel with scan length at center point
scalar.diffusion.map map.pgm 16 <10, 10, 10> // calculate diffusion map from one voxel with scan length at point <10,10,10>
scalar.diffusion.map map.pgm 16 <10, 10, 10> <-3, -3, -3> // calculate diffusion map from one voxel with scan length at point <7,7,7>
scalar.diffusion.map map.pgm 16 <0, 0, 0> <-3, -3, -3> // calculate diffusion map from one voxel with scan length at center point plus <-3,-3,-3>
scalar.diffusion.colormap map.ppm 16 ... // calculate diffusion map from one voxel with scan length at center point / ... see above
scalar.diffusion.dump dump.txt 16 ... // dump diffusion from one voxel with scan length at center point / ... see above
scalar.diffusion.histogram ... // calculate length histogram from one voxel at center point / ... see above
scalar.diffusion.sd ... // calculate SD's from one voxel at center point / ... see above

// Note: The diffusion method works best with isotropic voxels!
scalar.submethod 2 // 0=sum 1=mean 2=sd(default) 3=min 4=Q.25 5=median 6=Q.75 7=max
scalar.fullscan false // true = scan only full spheres (without zero), false(default) = scan incomplete spheres
scalar.diffusion.method 5 // 1=stark2013 2=stark2014a 3=stark2014b 4=stark2015a 5=stark2015b(default) 6=stark2019 // algorithm for scalar.diffusion
//       stark2013 = only the single best vector – vectorlength = submethod.SD
//       stark2014a = mean the two best vectors, if distance < r/2 – vectorlength = submethod.SD
//       stark2014b = mean (same submethod.SD) best vectors – vectorlength = submethod.SD
//       stark2015a = mean (same submethod.SD) best vectors (around diffusion.angle (rad)), only for diffusion.max (%)
//       stark2015b = mean the best vectors (around diffusion.angle (rad)), only for diffusion.max (%)
//       stark2019  = mean the best vectors (around diffusion.angle (rad)), only for diffusion.max (%) – vectorlength = submethod.SD
scalar.diffusion.max 0.25 // (%)
scalar.diffusion.angle 0.08726 // (rad) - 5*(pi/180) = 5°
scalar.diffusion 16 // calculate a vector field from a scalar with voxel scan length
scalar.diffusion.x2 8 // calculate a half sized vector field from a scalar with voxel scan length
scalar.diffusion.x3 5 // calculate a third sized vector field from a scalar with voxel scan length
scalar.diffusion.x4 4 // calculate a quarter sized vector field from a scalar with voxel scan length
scalar.diffusion.x5 3 // calculate a fifth sized vector field from a scalar with voxel scan length
scalar.diffusion.adaptive.x2 8 // calculate a half sized vector field from a scalar with voxel scan length - only for scalar div 2 or if fails for subpixels
scalar.diffusion.adaptive.x3 5 // calculate a third sized vector field from a scalar with voxel scan length - only for scalar div 3 or if fails for subpixels
scalar.diffusion.adaptive.x4 4 // calculate a quarter sized vector field from a scalar with voxel scan length - only for scalar div 4 or if fails for subpixels
scalar.diffusion.adaptive.x5 3 // calculate a fifth sized vector field from a scalar with voxel scan length - only for scalar div 5 or if fails for subpixels

// Note: The connection method works best with isotropic voxels (otherwise, you can test the .aniso methods)!
scalar.submethod 2 // 0=sum 1=mean 2=sd(default) 3=min 4=Q.25 5=median 6=Q.75 7=max
scalar.fullscan false // true = scan only full spheres (without zero), false(default) = scan incomplete spheres
scalar.connection.method 4 // 1=hdti 2=dti 3=ddti 4=hardhardi 5=softhardi(default) 6=hardi // algorithm for scalar.connection
//       hdti = similar to three direction (x,y,z)/2 diffusion imaging
//       dti = similar to seven direction (x,y,z + octants)/2 diffusion imaging
//       ddti = similar to thirteen direction 2*(x,y,z + octants + between x,y,z)/2 diffusion imaging
//       hardhardi = similar to high angular resolution diffusion imaging with limit of 64 orientation vectors
//       softhardi = similar to high angular resolution diffusion imaging with limit of 128 orientation vectors
//       hardi = similar to high angular resolution diffusion imaging
scalar.connection 16 // calculate a tensor field from a scalar with voxel scan length
scalar.connection.x2 8 // calculate a half sized tensor field from a scalar with voxel scan length
scalar.connection.x3 5 // calculate a third sized tensor field from a scalar with voxel scan length
scalar.connection.x4 4 // calculate a quarter sized tensor field from a scalar with voxel scan length
scalar.connection.x5 3 // calculate a fifth sized tensor field from a scalar with voxel scan length
scalar.connection.adaptive_x2 8 // calculate a half sized tensor field from a scalar with voxel scan length - only for scalar div 2 or if fails for subpixels
scalar.connection.adaptive_x3 5 // calculate a third sized tensor field from a scalar with voxel scan length - only for scalar div 3 or if fails for subpixels
scalar.connection.adaptive_x4 4 // calculate a quarter sized tensor field from a scalar with voxel scan length - only for scalar div 4 or if fails for subpixels
scalar.connection.adaptive_x5 3 // calculate a fifth sized tensor field from a scalar with voxel scan length - only for scalar div 5 or if fails for subpixels
scalar.connection.aniso 16 // calculate a tensor field from a scalar with min (anisotropic) voxel scan length (only for hardi)
scalar.connection.aniso.x2 8 // calculate a half sized tensor field from a scalar with min (anisotropic) voxel scan length (only for hardi)
scalar.connection.aniso.x3 5 // calculate a third sized tensor field from a scalar with min (anisotropic) voxel scan length (only for hardi)
scalar.connection.aniso.x4 4 // calculate a quarter sized tensor field from a scalar with min (anisotropic) voxel scan length (only for hardi)
scalar.connection.aniso.x5 3 // calculate a fifth sized tensor field from a scalar with min (anisotropic) voxel scan length (only for hardi)

